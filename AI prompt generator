    <script>
      (() => {
        const STORAGE = {
          theme: "promptsmith-theme",
          draft: "promptsmith-draft",
          leads: "promptsmith-leads"
        };

        const html = document.documentElement;
        const themeToggle = document.getElementById("themeToggle");
        const menuBtn = document.getElementById("menuBtn");
        const mobileNav = document.getElementById("mobileNav");
        const promptForm = document.getElementById("promptForm");
        const resetBtn = document.getElementById("resetBtn");
        const creativity = document.getElementById("creativity");
        const creativityValue = document.getElementById("creativityValue");
        const statusEl = document.getElementById("generatorStatus");
        const outputWrap = document.getElementById("outputWrap");
        const outputLabel = document.getElementById("outputLabel");
        const outputText = document.getElementById("outputText");
        const tabRow = document.getElementById("tabRow");
        const copyBtn = document.getElementById("copyBtn");
        const generateBtn = document.getElementById("generateBtn");
        const aiRefineInput = document.getElementById("aiRefine");
        const toolsError = document.getElementById("toolsError");

        // FIX (Tip): character counter elements
        const goalEl = document.getElementById("goal");
        const constraintsEl = document.getElementById("constraints");
        const goalCounter = document.getElementById("goalCounter");
        const constraintsCounter = document.getElementById("constraintsCounter");

        const leadForm = document.getElementById("leadForm");
        const leadStatus = document.getElementById("leadStatus");

        let promptsByTool = {};
        let activeTool = "";

        // FIX (UX): copyBtn timeout handle to prevent race condition
        let copyTimeout = null;

        // FIX (Tip): debounce timer for draft saving
        let draftTimer = null;

        // ─── Theme ───────────────────────────────────────────────────────────

        function setTheme(theme) {
          html.setAttribute("data-theme", theme);
          localStorage.setItem(STORAGE.theme, theme);
          // FIX (A11y): button text and aria-label always reflect the action (switch TO the other theme)
          const nextTheme = theme === "dark" ? "light" : "dark";
          const label = theme === "dark" ? "Light" : "Dark";
          themeToggle.textContent = label;
          themeToggle.setAttribute("aria-label", `Switch to ${nextTheme} mode`);
        }

        function initTheme() {
          const saved = localStorage.getItem(STORAGE.theme);
          if (saved === "dark" || saved === "light") {
            setTheme(saved);
            return;
          }
          const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
          setTheme(prefersDark ? "dark" : "light");
        }

        // ─── Menu ────────────────────────────────────────────────────────────

        function initMenu() {
          menuBtn?.addEventListener("click", () => {
            const isOpen = !mobileNav.hidden;
            mobileNav.hidden = isOpen;
            menuBtn.setAttribute("aria-expanded", String(!isOpen));
          });

          mobileNav?.querySelectorAll("a").forEach((link) => {
            link.addEventListener("click", () => {
              mobileNav.hidden = true;
              menuBtn.setAttribute("aria-expanded", "false");
            });
          });
        }

        // ─── Smooth scroll ───────────────────────────────────────────────────

        function initSmoothScroll() {
          document.querySelectorAll('a[href^="#"]').forEach((anchor) => {
            anchor.addEventListener("click", (event) => {
              const targetId = anchor.getAttribute("href");
              if (!targetId || targetId === "#") return;
              const target = document.querySelector(targetId);
              if (!target) return;
              event.preventDefault();
              target.scrollIntoView({ behavior: "smooth", block: "start" });
            });
          });
        }

        // ─── Reveal on scroll ────────────────────────────────────────────────

        function initReveal() {
          const observer = new IntersectionObserver(
            (entries) => {
              entries.forEach((entry) => {
                if (entry.isIntersecting) {
                  entry.target.classList.add("is-visible");
                  observer.unobserve(entry.target);
                }
              });
            },
            { threshold: 0.14 }
          );

          document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));
        }

        // ─── FAQ ─────────────────────────────────────────────────────────────

        function initFaq() {
          document.querySelectorAll(".faq-item").forEach((item) => {
            const btn = item.querySelector(".faq-trigger");
            const sign = item.querySelector(".faq-sign");
            btn.addEventListener("click", () => {
              const isOpen = item.classList.toggle("open");
              btn.setAttribute("aria-expanded", String(isOpen));
              sign.textContent = isOpen ? "-" : "+";
            });
          });
        }

        // ─── Char counters ───────────────────────────────────────────────────

        // FIX (Tip): live character counter with warning threshold
        function updateCharCounter(input, counter, max) {
          const len = input.value.length;
          counter.textContent = `${len} / ${max}`;
          counter.classList.toggle("warn", len > max * 0.85);
        }

        function initCharCounters() {
          const maxGoal = 1200;
          const maxConstraints = 800;

          goalEl.addEventListener("input", () => updateCharCounter(goalEl, goalCounter, maxGoal));
          constraintsEl.addEventListener("input", () => updateCharCounter(constraintsEl, constraintsCounter, maxConstraints));

          // Initialise counts from loaded draft values
          updateCharCounter(goalEl, goalCounter, maxGoal);
          updateCharCounter(constraintsEl, constraintsCounter, maxConstraints);
        }

        // ─── Prompt engine ───────────────────────────────────────────────────

        function formatModeLabel(value) {
          const map = {
            step_by_step: "a step-by-step implementation plan",
            email: "a polished email draft",
            social: "a social media content pack",
            strategy: "a concise strategy memo",
            code: "a code-focused technical response",
            custom: "a clearly structured custom format"
          };
          return map[value] || map.step_by_step;
        }

        function inferDomainHints(goalText) {
          const goal = goalText.toLowerCase();
          const dictionary = [
            {
              keys: ["sales", "outreach", "lead", "pipeline"],
              hints: [
                "Add one qualifying question before making recommendations.",
                "Use plain, benefit-first language and avoid pressure tactics.",
                "Ask for a concrete CTA with timeline."
              ]
            },
            {
              keys: ["code", "bug", "debug", "frontend", "react", "javascript"],
              hints: [
                "Require runnable examples where possible.",
                "Ask for edge cases and test strategy.",
                "Keep naming and architecture choices explicit."
              ]
            },
            {
              keys: ["marketing", "campaign", "brand", "copy", "ad"],
              hints: [
                "Include audience pain points before writing copy.",
                "Request 2-3 tonal alternatives with clear differences.",
                "Define one measurable conversion goal."
              ]
            },
            {
              keys: ["course", "lesson", "teacher", "education", "student"],
              hints: [
                "Use examples that fit mixed skill levels.",
                "Ask for short recap checkpoints.",
                "Prioritize clarity over jargon."
              ]
            }
          ];

          const match = dictionary.find((entry) => entry.keys.some((k) => goal.includes(k)));
          return match ? match.hints : ["Keep recommendations practical, not theoretical.", "Use examples with concrete numbers."];
        }

        function getCreativityGuidance(value) {
          if (value <= 35) return "Prioritize precision, fewer creative leaps, and tight wording.";
          if (value >= 70) return "Allow more experimentation, surprising angles, and unconventional options.";
          return "Balance creativity with practical execution details.";
        }

        function buildBasePrompt(data) {
          const domainHints = inferDomainHints(data.goal);
          const guidance = getCreativityGuidance(data.creativity);

          return [
            "You are an expert prompt engineer and domain specialist.",
            "",
            "## Objective",
            data.goal,
            "",
            "## Audience Context",
            data.audience,
            "",
            "## Output Expectations",
            `- Write in a ${data.tone} but natural voice.`,
            `- Return ${formatModeLabel(data.format)}.`,
            `- ${guidance}`,
            "- Include specific examples, not generic advice.",
            "",
            "## Constraints",
            data.constraints || "- No extra constraints provided. Keep the response sharp and practical.",
            "",
            "## Quality Guardrails",
            ...domainHints.map((hint) => `- ${hint}`),
            "- If context is missing, ask up to 3 clarifying questions first.",
            "",
            "## Final Check Before Answering",
            "- Verify the answer is actionable in real-world use.",
            "- Remove fluff and repetition.",
            "- Keep structure easy to scan."
          ].join("\n");
        }

        function buildToolSpecificPrompt(tool, basePrompt) {
          const wrappers = {
            chatgpt: {
              title: "ChatGPT",
              add: [
                "",
                "## ChatGPT-Specific Instructions",
                "- Use section headers and concise bullets.",
                "- Offer one improved version after the first draft.",
                "- End with a quick list of optional follow-up prompts."
              ]
            },
            claude: {
              title: "Claude",
              add: [
                "",
                "## Claude-Specific Instructions",
                "- Show reasoning briefly before final recommendations.",
                "- Highlight assumptions explicitly.",
                "- Add a short risk/limitations note when relevant."
              ]
            },
            gemini: {
              title: "Gemini",
              add: [
                "",
                "## Gemini-Specific Instructions",
                "- Keep language concise and strongly structured.",
                "- Use markdown headings and numbered steps.",
                '- Include a "Fast version" and "Detailed version" when useful.'
              ]
            },
            generic: {
              title: "Universal",
              add: [
                "",
                "## Universal Instructions",
                "- Keep this prompt portable across LLM platforms.",
                "- Avoid vendor-specific syntax unless necessary.",
                "- Maintain clear role, task, constraints, and output shape."
              ]
            }
          };

          const selected = wrappers[tool] || wrappers.generic;
          return {
            label: selected.title,
            prompt: `${basePrompt}${selected.add.join("\n")}`
          };
        }

        async function tryOnDeviceRefinement(rawPrompt, toolName) {
          const refineInstruction = [
            `Refine the following prompt for ${toolName}.`,
            "Do not change intent.",
            "Improve clarity, reduce redundancy, preserve structure.",
            "Return only the improved prompt text.",
            "",
            rawPrompt
          ].join("\n");

          try {
            if (window.ai && typeof window.ai.prompt === "function") {
              const output = await window.ai.prompt(refineInstruction);
              return typeof output === "string" && output.trim() ? output.trim() : null;
            }

            if (window.LanguageModel && typeof window.LanguageModel.create === "function") {
              const session = await window.LanguageModel.create({ temperature: 0.35, topK: 20 });
              const output = await session.prompt(refineInstruction);
              if (typeof session.destroy === "function") {
                await session.destroy();
              }
              return typeof output === "string" && output.trim() ? output.trim() : null;
            }
          } catch (_error) {
            return null;
          }

          return null;
        }

        // ─── Tab rendering ───────────────────────────────────────────────────

        // FIX (A11y): tabs get role="tab", aria-selected, and aria-controls pointing to the panel
        function renderTabs() {
          tabRow.innerHTML = "";
          const tools = Object.keys(promptsByTool);
          if (!tools.length) return;

          tools.forEach((tool, index) => {
            const btn = document.createElement("button");
            btn.type = "button";
            btn.className = "tab-btn" + (tool === activeTool ? " active" : "");
            btn.textContent = promptsByTool[tool].label;
            btn.setAttribute("role", "tab");
            btn.setAttribute("aria-selected", tool === activeTool ? "true" : "false");
            btn.setAttribute("aria-controls", "outputText");
            btn.id = `tab-${tool}`;
            btn.addEventListener("click", () => {
              activeTool = tool;
              updateOutputCard();
            });
            tabRow.appendChild(btn);
          });
        }

        function updateOutputCard() {
          const active = promptsByTool[activeTool];
          if (!active) return;
          outputLabel.textContent = `${active.label} Prompt`;
          outputText.textContent = active.prompt;
          // FIX (A11y): sync aria-selected on all tab buttons
          tabRow.querySelectorAll(".tab-btn").forEach((btn) => {
            const isActive = btn.id === `tab-${activeTool}`;
            btn.classList.toggle("active", isActive);
            btn.setAttribute("aria-selected", isActive ? "true" : "false");
          });
        }

        // ─── Draft persistence ───────────────────────────────────────────────

        function saveDraft() {
          const formData = new FormData(promptForm);
          const payload = {
            goal: formData.get("goal") || "",
            audience: formData.get("audience") || "",
            format: formData.get("format") || "step_by_step",
            tone: formData.get("tone") || "confident",
            constraints: formData.get("constraints") || "",
            tools: formData.getAll("tools"),
            creativity: Number(formData.get("creativity") || 55),
            aiRefine: aiRefineInput.checked
          };
          localStorage.setItem(STORAGE.draft, JSON.stringify(payload));
        }

        function loadDraft() {
          const raw = localStorage.getItem(STORAGE.draft);
          if (!raw) return;
          try {
            const data = JSON.parse(raw);
            if (typeof data.goal === "string") document.getElementById("goal").value = data.goal;
            if (typeof data.audience === "string") document.getElementById("audience").value = data.audience;
            if (typeof data.format === "string") document.getElementById("format").value = data.format;
            if (typeof data.constraints === "string") document.getElementById("constraints").value = data.constraints;
            if (typeof data.creativity === "number") {
              creativity.value = String(data.creativity);
              creativityValue.textContent = String(data.creativity);
            }
            if (typeof data.aiRefine === "boolean") aiRefineInput.checked = data.aiRefine;

            if (typeof data.tone === "string") {
              const tone = promptForm.querySelector(`input[name="tone"][value="${data.tone}"]`);
              if (tone) tone.checked = true;
            }

            if (Array.isArray(data.tools) && data.tools.length) {
              promptForm.querySelectorAll('input[name="tools"]').forEach((input) => {
                input.checked = data.tools.includes(input.value);
              });
            }
          } catch (_error) {
            // FIX (Tip): log a warning so corrupted drafts are visible during development
            console.warn("PromptSmith: corrupted draft cleared", _error);
            localStorage.removeItem(STORAGE.draft);
          }
        }

        // ─── Generate ────────────────────────────────────────────────────────

        async function handleGenerate(event) {
          event.preventDefault();

          const formData = new FormData(promptForm);
          const selectedTools = formData.getAll("tools");

          // FIX (UX): show error inline near the tool pills, not only in the status bar
          if (!selectedTools.length) {
            toolsError.classList.add("visible");
            toolsError.focus();
            return;
          }
          toolsError.classList.remove("visible");

          const data = {
            goal: String(formData.get("goal") || "").trim(),
            audience: String(formData.get("audience") || "").trim(),
            format: String(formData.get("format") || "step_by_step"),
            tone: String(formData.get("tone") || "confident"),
            constraints: String(formData.get("constraints") || "").trim(),
            creativity: Number(formData.get("creativity") || 55)
          };

          if (!data.goal || !data.audience) {
            statusEl.textContent = "Add your goal and audience context first.";
            return;
          }

          generateBtn.disabled = true;
          generateBtn.textContent = "Generating...";
          statusEl.textContent = "Building prompts with the local prompt engine...";

          const basePrompt = buildBasePrompt(data);
          const draftOutputs = {};

          selectedTools.forEach((tool) => {
            draftOutputs[tool] = buildToolSpecificPrompt(tool, basePrompt);
          });

          let usedOnDeviceAI = false;
          if (aiRefineInput.checked) {
            statusEl.textContent = "Trying on-device AI refinement (if supported by your browser)...";
            for (const [tool, value] of Object.entries(draftOutputs)) {
              const refined = await tryOnDeviceRefinement(value.prompt, value.label);
              if (refined) {
                draftOutputs[tool] = { ...value, prompt: refined };
                usedOnDeviceAI = true;
              }
            }
          }

          promptsByTool = draftOutputs;
          activeTool = Object.keys(promptsByTool)[0];
          renderTabs();
          updateOutputCard();
          outputWrap.hidden = false;

          if (aiRefineInput.checked && !usedOnDeviceAI) {
            statusEl.textContent = "Browser AI not available, so I used the built-in local prompt logic. Results are still ready.";
          } else {
            statusEl.textContent = usedOnDeviceAI
              ? "Prompts generated and polished with on-device AI."
              : "Prompts generated successfully.";
          }

          saveDraft();
          generateBtn.disabled = false;
          generateBtn.textContent = "Generate Prompt";

          // Scroll output into view so users know it's ready
          outputWrap.scrollIntoView({ behavior: "smooth", block: "nearest" });
        }

        // ─── Copy ────────────────────────────────────────────────────────────

        async function copyActivePrompt() {
          const active = promptsByTool[activeTool];
          if (!active?.prompt) return;
          try {
            await navigator.clipboard.writeText(active.prompt);
            // FIX (UX): clear any existing timeout before setting a new one to avoid race condition
            clearTimeout(copyTimeout);
            copyBtn.textContent = "Copied";
            copyTimeout = setTimeout(() => (copyBtn.textContent = "Copy"), 1400);
          } catch (_error) {
            statusEl.textContent = "Clipboard access failed. You can still copy manually from the prompt panel.";
          }
        }

        // ─── Reset ───────────────────────────────────────────────────────────

        function resetGenerator() {
          promptForm.reset();
          creativity.value = "55";
          creativityValue.textContent = "55";
          promptsByTool = {};
          activeTool = "";
          outputWrap.hidden = true;
          tabRow.innerHTML = "";
          outputText.textContent = "";
          toolsError.classList.remove("visible");

          // FIX (Tip): reset char counters after form reset
          updateCharCounter(goalEl, goalCounter, 1200);
          updateCharCounter(constraintsEl, constraintsCounter, 800);

          statusEl.textContent = "Generator reset. Start with a fresh brief.";
          localStorage.removeItem(STORAGE.draft);

          // FIX (UX): scroll back to generator top so user sees the cleared form
          document.getElementById("generator").scrollIntoView({ behavior: "smooth", block: "start" });
        }

        // ─── Lead form ───────────────────────────────────────────────────────

        function initLeadForm() {
          leadForm.addEventListener("submit", (event) => {
            event.preventDefault();

            // FIX (Bug): use leadForm.elements to safely access named fields,
            // avoiding collision with the native HTMLElement.name property
            const nameEl = leadForm.elements.namedItem("name");
            const emailEl = leadForm.elements.namedItem("email");

            const payload = {
              name: nameEl.value.trim(),
              email: emailEl.value.trim(),
              timestamp: new Date().toISOString()
            };

            if (!payload.name || !payload.email) {
              leadStatus.textContent = "Please add both name and email.";
              return;
            }

            const saved = JSON.parse(localStorage.getItem(STORAGE.leads) || "[]");
            saved.push(payload);
            localStorage.setItem(STORAGE.leads, JSON.stringify(saved));

            leadStatus.textContent = `Thanks ${payload.name.split(" ")[0]} — you're in. Demo entry saved locally.`;
            leadForm.reset();
          });
        }

        // ─── Form bindings ───────────────────────────────────────────────────

        function initFormBindings() {
          creativity.addEventListener("input", () => {
            creativityValue.textContent = creativity.value;
          });

          // FIX (Tip): debounce draft saving by 350ms to avoid thrashing localStorage on every keystroke
          promptForm.addEventListener("input", () => {
            clearTimeout(draftTimer);
            draftTimer = setTimeout(saveDraft, 350);
          });

          promptForm.addEventListener("submit", handleGenerate);
          copyBtn.addEventListener("click", copyActivePrompt);
          resetBtn.addEventListener("click", resetGenerator);
        }

        // ─── Init ────────────────────────────────────────────────────────────

        function init() {
          initTheme();
          initMenu();
          initSmoothScroll();
          initReveal();
          initFaq();
          loadDraft();
          initFormBindings();
          initLeadForm();
          initCharCounters();

          themeToggle.addEventListener("click", () => {
            const current = html.getAttribute("data-theme") || "light";
            setTheme(current === "dark" ? "light" : "dark");
          });

          // FIX (Tip): textContent coerces numbers — no String() wrapper needed
          document.getElementById("year").textContent = new Date().getFullYear();
        }

        init();
      })();
    </script>
  </body>
</html>
