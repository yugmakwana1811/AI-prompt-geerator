<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>PromptSmith Studio | AI Prompt Generator for ChatGPT, Claude & Gemini</title>
    <meta
      name="description"
      content="PromptSmith Studio helps you craft higher-quality prompts for ChatGPT, Claude, Gemini, and other AI tools. Premium frontend-only web app with smart prompt generation, theme toggle, and zero backend."
    />
    <meta name="theme-color" content="#0a7f6f" />
    <meta property="og:title" content="PromptSmith Studio | AI Prompt Generator" />
    <meta
      property="og:description"
      content="Generate cleaner, sharper prompts in seconds. Built for creators, teams, and curious builders."
    />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Sans:wght@400;500;600;700&family=Sora:wght@500;600;700;800&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        color-scheme: light;
        --bg: #f5f6f4;
        --surface: rgba(255, 255, 255, 0.86);
        --surface-strong: #ffffff;
        --text: #101514;
        --muted: #596764;
        --brand: #0a7f6f;
        --brand-2: #e18f2b;
        --line: rgba(16, 21, 20, 0.1);
        --shadow: 0 20px 60px rgba(13, 31, 27, 0.1);
        --radius-xl: 26px;
        --radius-lg: 18px;
        --radius-md: 12px;
        --max: 1140px;
      }

      [data-theme="dark"] {
        color-scheme: dark;
        --bg: #0d1413;
        --surface: rgba(20, 30, 28, 0.85);
        --surface-strong: #13211f;
        --text: #eaf3f1;
        --muted: #9cb0ac;
        --brand: #4fd7c3;
        --brand-2: #f3a64a;
        --line: rgba(236, 251, 247, 0.12);
        --shadow: 0 24px 60px rgba(0, 0, 0, 0.35);
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        font-family: "Instrument Sans", sans-serif;
        color: var(--text);
        background: var(--bg);
        line-height: 1.6;
      }

      body::before,
      body::after {
        content: "";
        position: fixed;
        z-index: -1;
        inset: auto;
        border-radius: 999px;
        filter: blur(70px);
        opacity: 0.45;
        pointer-events: none;
      }

      body::before {
        width: 420px;
        height: 420px;
        background: color-mix(in oklab, var(--brand) 60%, transparent);
        top: -100px;
        right: -90px;
      }

      body::after {
        width: 380px;
        height: 380px;
        background: color-mix(in oklab, var(--brand-2) 45%, transparent);
        bottom: -140px;
        left: -80px;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      img {
        max-width: 100%;
        display: block;
      }

      .container {
        width: min(100% - 2.4rem, var(--max));
        margin-inline: auto;
      }

      .site-header {
        position: sticky;
        top: 0;
        z-index: 40;
        backdrop-filter: blur(12px);
        background: color-mix(in oklab, var(--bg) 86%, transparent);
        border-bottom: 1px solid var(--line);
      }

      .nav-wrap {
        min-height: 72px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
      }

      .brand {
        display: inline-flex;
        align-items: center;
        gap: 0.7rem;
        font-weight: 700;
        letter-spacing: -0.02em;
      }

      .brand-mark {
        width: 34px;
        aspect-ratio: 1;
        display: grid;
        place-items: center;
        font-family: "Sora", sans-serif;
        font-size: 0.95rem;
        border-radius: 11px;
        color: #fff;
        background: linear-gradient(135deg, var(--brand), color-mix(in oklab, var(--brand-2) 45%, var(--brand)));
        box-shadow: var(--shadow);
      }

      .nav {
        display: none;
        gap: 1rem;
        align-items: center;
      }

      .nav a {
        font-weight: 600;
        color: var(--muted);
        transition: color 180ms ease;
      }

      .nav a:hover,
      .nav a:focus-visible {
        color: var(--text);
      }

      .nav-actions {
        display: flex;
        align-items: center;
        gap: 0.6rem;
      }

      .ghost-btn,
      .solid-btn,
      .menu-btn {
        border: 1px solid var(--line);
        background: var(--surface);
        color: var(--text);
        border-radius: 999px;
        padding: 0.6rem 0.95rem;
        font: inherit;
        cursor: pointer;
        transition: transform 180ms ease, background 180ms ease, border-color 180ms ease;
      }

      .ghost-btn:hover,
      .solid-btn:hover,
      .menu-btn:hover {
        transform: translateY(-1px);
      }

      .solid-btn {
        background: var(--brand);
        color: #fff;
        border-color: transparent;
        font-weight: 700;
      }

      .menu-btn {
        display: grid;
        place-items: center;
        padding-inline: 0.8rem;
      }

      .mobile-nav {
        display: grid;
        gap: 0.4rem;
        padding-bottom: 0.8rem;
      }

      .mobile-nav[hidden] {
        display: none;
      }

      .mobile-nav a {
        padding: 0.55rem 0.75rem;
        border-radius: 10px;
        color: var(--muted);
        border: 1px solid transparent;
      }

      .mobile-nav a:hover,
      .mobile-nav a:focus-visible {
        border-color: var(--line);
        background: var(--surface);
        color: var(--text);
      }

      .hero {
        padding-block: 4.4rem 3rem;
      }

      .hero-grid {
        display: grid;
        gap: 2.3rem;
      }

      .eyebrow {
        width: fit-content;
        margin: 0 0 1rem;
        padding: 0.35rem 0.75rem;
        border-radius: 999px;
        background: color-mix(in oklab, var(--brand) 16%, transparent);
        color: var(--brand);
        font-weight: 700;
        font-size: 0.82rem;
      }

      h1,
      h2,
      h3 {
        font-family: "Sora", sans-serif;
        letter-spacing: -0.03em;
        margin: 0;
        line-height: 1.08;
      }

      h1 {
        font-size: clamp(2rem, 5.3vw, 4rem);
        max-width: 18ch;
      }

      .hero p {
        margin: 1.2rem 0 0;
        color: var(--muted);
        max-width: 58ch;
        font-size: clamp(1rem, 1.5vw, 1.2rem);
      }

      .cta-row {
        margin-top: 1.7rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.8rem;
      }

      .stats-row {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 0.7rem;
      }

      .chip {
        border: 1px solid var(--line);
        border-radius: var(--radius-md);
        padding: 0.9rem;
        background: var(--surface);
      }

      .chip strong {
        display: block;
        font-family: "Sora", sans-serif;
        font-size: 1.2rem;
      }

      .chip span {
        color: var(--muted);
        font-size: 0.92rem;
      }

      .section {
        padding-block: 3.2rem;
      }

      .section-head {
        margin-bottom: 1.4rem;
      }

      .section-head p {
        margin-top: 0.75rem;
        color: var(--muted);
        max-width: 64ch;
      }

      .card-grid {
        display: grid;
        gap: 1rem;
      }

      .card {
        border: 1px solid var(--line);
        border-radius: var(--radius-lg);
        background: var(--surface);
        box-shadow: var(--shadow);
        padding: 1.1rem;
        transition: transform 220ms ease, border-color 220ms ease;
      }

      .card:hover {
        transform: translateY(-4px);
        border-color: color-mix(in oklab, var(--brand) 35%, var(--line));
      }

      .card h3 {
        font-size: 1.1rem;
      }

      .card p {
        margin: 0.7rem 0 0;
        color: var(--muted);
      }

      .generator {
        border: 1px solid var(--line);
        border-radius: var(--radius-xl);
        background: var(--surface);
        box-shadow: var(--shadow);
        padding: 1rem;
      }

      .generator-grid {
        display: grid;
        gap: 1rem;
      }

      .field {
        display: grid;
        gap: 0.45rem;
      }

      .field label {
        font-weight: 600;
      }

      input,
      textarea,
      select {
        width: 100%;
        padding: 0.78rem 0.9rem;
        font: inherit;
        color: var(--text);
        background: var(--surface-strong);
        border: 1px solid var(--line);
        border-radius: 12px;
        resize: vertical;
      }

      textarea {
        min-height: 110px;
      }

      input:focus-visible,
      textarea:focus-visible,
      select:focus-visible,
      button:focus-visible,
      a:focus-visible {
        outline: 3px solid color-mix(in oklab, var(--brand) 50%, transparent);
        outline-offset: 2px;
      }

      .tool-pills,
      .tone-pills {
        display: flex;
        flex-wrap: wrap;
        gap: 0.45rem;
      }

      /* FIX (Bug): Pill inputs use accessibility-hiding instead of pointer-events:none
         so keyboard users can focus and activate them normally. */
      .pill {
        position: relative;
      }

      .pill input {
        position: absolute;
        clip-path: inset(50%);
        width: 1px;
        height: 1px;
        overflow: hidden;
        white-space: nowrap;
      }

      .pill span {
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        padding: 0.48rem 0.78rem;
        border-radius: 999px;
        border: 1px solid var(--line);
        background: var(--surface-strong);
        font-size: 0.9rem;
        cursor: pointer;
        transition: all 180ms ease;
      }

      .pill input:checked + span {
        border-color: color-mix(in oklab, var(--brand) 55%, var(--line));
        background: color-mix(in oklab, var(--brand) 17%, var(--surface-strong));
      }

      /* FIX (A11y): Focus ring visible on pill inputs for keyboard users */
      .pill input:focus-visible + span {
        outline: 3px solid color-mix(in oklab, var(--brand) 50%, transparent);
        outline-offset: 2px;
      }

      .slider-row {
        display: grid;
        grid-template-columns: 1fr auto;
        gap: 0.6rem;
        align-items: center;
      }

      .slider-row output {
        font-weight: 700;
        min-width: 3ch;
        text-align: right;
      }

      .helper {
        font-size: 0.88rem;
        color: var(--muted);
      }

      /* FIX (Tip): pill--inline modifier class instead of inline style */
      .pill--inline {
        width: fit-content;
      }

      .generator-actions {
        display: flex;
        flex-wrap: wrap;
        gap: 0.65rem;
        align-items: center;
      }

      .status {
        font-size: 0.9rem;
        color: var(--muted);
        min-height: 1.3em;
      }

      /* FIX (UX): inline field error shown near the relevant input */
      .field-error {
        font-size: 0.85rem;
        color: #c0392b;
        min-height: 1.1em;
        display: none;
      }

      .field-error.visible {
        display: block;
      }

      .output-wrap {
        margin-top: 1.2rem;
        border-top: 1px solid var(--line);
        padding-top: 1rem;
      }

      /* FIX (A11y): tablist role applied via JS; these styles support the ARIA tab pattern */
      .tab-row {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
      }

      .tab-btn {
        border-radius: 999px;
        border: 1px solid var(--line);
        background: var(--surface-strong);
        color: var(--muted);
        padding: 0.45rem 0.8rem;
        font: inherit;
        cursor: pointer;
      }

      .tab-btn.active,
      .tab-btn[aria-selected="true"] {
        border-color: color-mix(in oklab, var(--brand) 55%, var(--line));
        background: color-mix(in oklab, var(--brand) 15%, var(--surface-strong));
        color: var(--text);
      }

      .output-card {
        margin-top: 0.85rem;
        border: 1px solid var(--line);
        background: var(--surface-strong);
        border-radius: 14px;
        overflow: hidden;
      }

      .output-head {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 0.7rem;
        padding: 0.65rem 0.8rem;
        border-bottom: 1px solid var(--line);
      }

      .output-head strong {
        font-size: 0.92rem;
      }

      .output-body {
        margin: 0;
        padding: 0.95rem;
        white-space: pre-wrap;
        font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, "Liberation Mono", monospace;
        font-size: 0.87rem;
        max-height: 340px;
        overflow: auto;
      }

      /* FIX (UX): character counter warning */
      .char-counter {
        font-size: 0.82rem;
        color: var(--muted);
        text-align: right;
        transition: color 200ms ease;
      }

      .char-counter.warn {
        color: #c0392b;
        font-weight: 600;
      }

      .about {
        border: 1px solid var(--line);
        border-radius: var(--radius-xl);
        background: var(--surface);
        box-shadow: var(--shadow);
        padding: 1.2rem;
      }

      .about p {
        color: var(--muted);
      }

      .testi-grid {
        display: grid;
        gap: 1rem;
      }

      blockquote {
        margin: 0;
        padding: 1rem;
        border: 1px solid var(--line);
        border-radius: 15px;
        background: var(--surface);
        box-shadow: var(--shadow);
      }

      blockquote p {
        margin: 0;
        color: var(--text);
      }

      blockquote footer {
        margin-top: 0.85rem;
        color: var(--muted);
        font-size: 0.9rem;
      }

      .faq-list {
        display: grid;
        gap: 0.7rem;
      }

      .faq-item {
        border: 1px solid var(--line);
        border-radius: 12px;
        background: var(--surface);
      }

      .faq-trigger {
        width: 100%;
        text-align: left;
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: center;
        padding: 0.9rem;
        font: inherit;
        color: var(--text);
        border: 0;
        border-radius: inherit;
        background: transparent;
        cursor: pointer;
      }

      .faq-panel {
        max-height: 0;
        overflow: hidden;
        transition: max-height 250ms ease;
      }

      .faq-panel p {
        margin: 0;
        padding: 0 0.9rem 0.9rem;
        color: var(--muted);
      }

      .faq-item.open .faq-panel {
        max-height: 220px;
      }

      .faq-sign {
        font-weight: 700;
        color: var(--brand);
      }

      .cta {
        border: 1px solid var(--line);
        border-radius: var(--radius-xl);
        background: linear-gradient(
          135deg,
          color-mix(in oklab, var(--brand) 18%, var(--surface)) 0%,
          color-mix(in oklab, var(--brand-2) 14%, var(--surface)) 100%
        );
        box-shadow: var(--shadow);
        padding: 1.2rem;
      }

      .cta p {
        color: var(--muted);
      }

      .inline-form {
        display: grid;
        gap: 0.75rem;
      }

      .success {
        color: color-mix(in oklab, var(--brand) 80%, #2ca571);
        font-weight: 600;
        min-height: 1.2em;
      }

      .site-footer {
        padding-block: 2rem 2.7rem;
        color: var(--muted);
        font-size: 0.92rem;
      }

      .reveal {
        opacity: 0;
        transform: translateY(18px);
        transition: opacity 480ms ease, transform 480ms ease;
      }

      .reveal.is-visible {
        opacity: 1;
        transform: translateY(0);
      }

      @media (min-width: 720px) {
        .nav {
          display: flex;
        }

        .menu-btn,
        .mobile-nav {
          display: none;
        }

        .hero-grid {
          grid-template-columns: 1.2fr 0.8fr;
          align-items: start;
        }

        .card-grid {
          grid-template-columns: repeat(3, minmax(0, 1fr));
        }

        .generator {
          padding: 1.2rem;
        }

        .generator-grid {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        .generator-grid .full {
          grid-column: 1 / -1;
        }

        .testi-grid {
          grid-template-columns: repeat(3, minmax(0, 1fr));
        }

        .inline-form {
          grid-template-columns: 1fr 1fr auto;
          align-items: end;
        }
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <div class="container nav-wrap">
        <a class="brand" href="#top" aria-label="PromptSmith home">
          <span class="brand-mark">PS</span>
          <span>PromptSmith Studio</span>
        </a>

        <nav class="nav" aria-label="Primary navigation">
          <a href="#generator">Generator</a>
          <a href="#features">Features</a>
          <a href="#about">About</a>
          <a href="#testimonials">Testimonials</a>
          <a href="#faq">FAQ</a>
        </nav>

        <div class="nav-actions">
          <!-- FIX (A11y): Initial label reflects actual current theme, set correctly by JS on load -->
          <button id="themeToggle" class="ghost-btn" type="button" aria-label="Switch to dark mode">
            Dark
          </button>
          <a class="solid-btn" href="#cta">Get Started</a>
          <button id="menuBtn" class="menu-btn" type="button" aria-expanded="false" aria-controls="mobileNav">
            Menu
          </button>
        </div>
      </div>

      <nav id="mobileNav" class="container mobile-nav" hidden>
        <a href="#generator">Generator</a>
        <a href="#features">Features</a>
        <a href="#about">About</a>
        <a href="#testimonials">Testimonials</a>
        <a href="#faq">FAQ</a>
        <a href="#cta">Get Started</a>
      </nav>
    </header>

    <main id="top">
      <section class="hero container section reveal">
        <div class="hero-grid">
          <div>
            <p class="eyebrow">Prompt engineering without the overthinking</p>
            <h1>Write better prompts in minutes, not after 17 random retries.</h1>
            <p>
              PromptSmith Studio helps you build high-quality prompts for ChatGPT, Claude, Gemini, and pretty much any
              other AI tool you already use. It asks the right questions, keeps the output structured, and saves your
              settings so you can move fast tomorrow too.
            </p>
            <div class="cta-row">
              <a class="solid-btn" href="#generator">Build My Prompt</a>
              <a class="ghost-btn" href="#features">See How It Works</a>
            </div>
          </div>
          <div class="stats-row" aria-label="Quick stats">
            <article class="chip">
              <strong>42%</strong>
              <span>Average cut in back-and-forth edits</span>
            </article>
            <article class="chip">
              <strong>5x</strong>
              <span>Faster prompt setup for recurring tasks</span>
            </article>
            <article class="chip">
              <strong>0</strong>
              <span>Servers, APIs, or backend dependencies</span>
            </article>
          </div>
        </div>
      </section>

      <section id="generator" class="container section reveal" aria-labelledby="generatorTitle">
        <div class="section-head">
          <h2 id="generatorTitle">AI Prompt Generator</h2>
          <p>
            Tell us what you need, pick your target tools, and generate prompt drafts tuned for each model style. You
            can even try optional on-device AI refinement if your browser supports it.
          </p>
        </div>

        <section class="generator" aria-label="Prompt generator form">
          <form id="promptForm" class="generator-grid">
            <div class="field full">
              <label for="goal">What are you trying to get done?</label>
              <textarea
                id="goal"
                name="goal"
                placeholder="Example: Create a 3-email onboarding sequence for a budgeting app targeting first-time freelancers."
                required
                maxlength="1200"
              ></textarea>
              <!-- FIX (Tip): live character counter for goal -->
              <div class="char-counter" id="goalCounter">0 / 1200</div>
            </div>

            <div class="field">
              <label for="audience">Audience / context</label>
              <input
                id="audience"
                name="audience"
                type="text"
                placeholder="e.g. startup founders, teachers, indie devs"
                required
              />
            </div>

            <div class="field">
              <label for="format">Output format</label>
              <select id="format" name="format">
                <option value="step_by_step">Step-by-step plan</option>
                <option value="email">Email draft</option>
                <option value="social">Social content pack</option>
                <option value="strategy">Strategy memo</option>
                <option value="code">Code-focused response</option>
                <option value="custom">Custom structure</option>
              </select>
            </div>

            <div class="field full">
              <label>Preferred tone</label>
              <div class="tone-pills" role="group" aria-label="Tone options">
                <label class="pill"><input type="radio" name="tone" value="confident" checked /><span>Confident</span></label>
                <label class="pill"><input type="radio" name="tone" value="friendly" /><span>Friendly</span></label>
                <label class="pill"><input type="radio" name="tone" value="direct" /><span>Direct</span></label>
                <label class="pill"><input type="radio" name="tone" value="playful" /><span>Playful</span></label>
                <label class="pill"><input type="radio" name="tone" value="technical" /><span>Technical</span></label>
              </div>
            </div>

            <div class="field full">
              <label>Target AI tool(s)</label>
              <!-- FIX (A11y + UX): aria-describedby links the error message to this group -->
              <div class="tool-pills" role="group" aria-label="Target AI tools" aria-describedby="toolsError">
                <label class="pill"><input type="checkbox" name="tools" value="chatgpt" checked /><span>ChatGPT</span></label>
                <label class="pill"><input type="checkbox" name="tools" value="claude" checked /><span>Claude</span></label>
                <label class="pill"><input type="checkbox" name="tools" value="gemini" checked /><span>Gemini</span></label>
                <label class="pill"><input type="checkbox" name="tools" value="generic" /><span>Universal</span></label>
              </div>
              <!-- FIX (UX): Error shown inline near the pills, not in a distant status bar -->
              <div class="field-error" id="toolsError" role="alert">Pick at least one target AI tool before generating.</div>
            </div>

            <div class="field full">
              <label for="constraints">Constraints (optional)</label>
              <textarea
                id="constraints"
                name="constraints"
                placeholder="Example: Keep under 220 words per email, avoid hype language, include one concrete metric."
                maxlength="800"
              ></textarea>
              <!-- FIX (Tip): live character counter for constraints -->
              <div class="char-counter" id="constraintsCounter">0 / 800</div>
            </div>

            <div class="field">
              <label for="creativity">Creativity level</label>
              <div class="slider-row">
                <input id="creativity" name="creativity" type="range" min="10" max="90" value="55" step="1" />
                <output id="creativityValue" for="creativity">55</output>
              </div>
              <div class="helper">Lower = tighter + practical. Higher = more exploratory.</div>
            </div>

            <div class="field">
              <!-- FIX (Tip): pill--inline modifier class replaces inline style -->
              <label class="pill pill--inline">
