    <footer class="site-footer container">
      <!-- FIX (Tip): removed unnecessary String() wrapper; textContent coerces numbers automatically -->
      <p>&copy; <span id="year"></span> PromptSmith Studio. Built with HTML, CSS, and JavaScript only.</p>
